# Khuôn mẫu cấu hình máy in. Chép thành .env rồi điền giá trị thật.
#   copy .env.example .env
#
# LƯU Ý BẢO MẬT: .env là PLAINTEXT trên đĩa, KHÔNG mã hoá.
# Nó chỉ giúp tránh commit nhầm lên git (đã có trong .gitignore).
# Muốn secret KHÔNG nằm trong thư mục dự án, hãy đặt biến môi trường ở cấp hệ điều hành:
#   setx BAMBU_HOST 192.168.1.50
#   setx BAMBU_SERIAL <SERIAL>
#   setx BAMBU_ACCESS_CODE <CODE>

BAMBU_HOST=REPLACE_WITH_PRINTER_IP
BAMBU_SERIAL=REPLACE_WITH_PRINTER_SERIAL
BAMBU_ACCESS_CODE=REPLACE_WITH_LAN_ACCESS_CODE

# ===== THONG BAO CHUONG (dien kenh nao muon dung, bo trong = tat) =====
# Telegram: tao bot qua @BotFather (/newbot) -> token; chat id: nhan tin cho bot
# roi hub tu do, hoac hoi @userinfobot. Bot 2 chieu: nut nhanh + AI + dieu khien.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy (app iOS/Android mien phi): dat topic kho doan roi subscribe trong app
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# Discord: Server Settings > Integrations > Webhooks > New > Copy URL
DISCORD_WEBHOOK=

# Link dashboard (Tailscale/LAN) — dinh kem vao tin bao de mo camera nhanh
HUB_URL=

# ===== AI HOI DAP + VISION (OpenRouter — https://openrouter.ai/keys) =====
OPENROUTER_API_KEY=
# Model hoi dap text (free); AI tu fallback: model nay -> Nano Omni free -> tra phi
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# Model nhin anh camera (dau loai thang tren frame that: mo ta dung vat the, 3s, $0.10/1M)
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash-lite
# Model tra phi cuoi chuoi fallback (~$0.0001/cau)
OPENROUTER_PAID_MODEL=openai/gpt-5-nano
