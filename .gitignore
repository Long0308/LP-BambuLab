# Cấu hình máy in THẬT — chứa host / serial / access_code (LAN access code).
# Dùng printer.local.example.json làm khuôn; chạy `python bambu_connect.py` để sinh file này.
printer.local.json

# Secret dạng .env (cùng mức bảo vệ: plaintext, chỉ tránh commit nhầm).
.env

# Dữ liệu cục bộ theo người dùng — KHÔNG commit (comment phải ở dòng riêng)
# gam nhựa từng cuộn (theo tag_uid RFID)
filament.local.json
# cache ảnh model + gam + thông số từng file in tải qua FTP
job_cache/

# KHÔNG BAO GIỜ tạo lại file này: Claude Code tự nạp project-scoped MCP server từ .mcp.json,
# tức là trao quyền điều khiển máy in (in / huỷ / chỉnh nhiệt / xoá file) cho AI.
# Mọi điều khiển phải do người dùng bấm trên web dashboard. Xem README mục "Bảo mật".
.mcp.json

# Local tooling
.claude/settings.local.json
.qodo/
temp/

# Trang lỗi HTTP bị lưu nhầm thành .json (429 / 404), không phải dữ liệu.
# Muốn commit vẫn được: git add -f A1_04.json A1_base.json
A1_04.json
A1_base.json

# Artifacts
__pycache__/
*.pyc
node_modules/
*.gcode
*.gcode.3mf

# File tam cua pipeline slice tren server (upload -> CLI slice -> day xuong may)
slice_jobs/

# Log server
dashboard.log
server.log

# nhat ky gui thong bao (runtime)
notify.log
ai_usage.json
