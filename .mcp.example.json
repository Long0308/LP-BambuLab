{
  "mcpServers": {
    "bambu-printer": {
      "command": "npx",
      "args": ["-y", "@rowbotik/bambu-printer-mcp"],
      "env": {
        "PRINTER_HOST": "REPLACE_WITH_PRINTER_IP",
        "BAMBU_SERIAL": "REPLACE_WITH_PRINTER_SERIAL",
        "BAMBU_TOKEN": "REPLACE_WITH_LAN_ACCESS_CODE"
      }
    }
  }
}
